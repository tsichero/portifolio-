/* Reset básico */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

/* Corpo da página */
body {
    font-family: Arial, sans-serif;
    background-color: #f9f9f9;
    color: #333;
    line-height: 1.6;
}

/* Header */
header {
    background-color: #ff6f3c;
    color: #fff;
    padding: 20px 0;
    text-align: center;
}

header p {
    font-size: 1rem;
    margin-top: 5px;
}

/* Menu de navegação */
nav ul {
    list-style: none;
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-top: 10px;
}

nav ul li a {
    color: #fff;
    text-decoration: none;
    font-weight: bold;
    transition: 0.3s;
}

nav ul li a:hover {
    color: #333;
}

/* Seções */
section {
    max-width: 900px;
    margin: 40px auto;
    padding: 20px;
}

h2 {
    color: #ff6f3c;
    margin-bottom: 15px;
}

/* Lista de projetos */
ul li {
    margin-bottom: 10px;
}

/* Formulário */
form input, form textarea {
    width: 100%;
    padding: 10px;
    margin-top: 5px;
    margin-bottom: 15px;
    border: 1px solid #ccc;
    border-radius: 5px;
}

form button {
    background-color: #ff6f3c;
    color: #fff;
    border: none;
    padding: 10px 20px;
    cursor: pointer;
    font-weight: bold;
    border-radius: 5px;
    transition: 0.3s;
}

form button:hover {
    background-color: #e65c2c;
}

/* Mensagem de confirmação */
.mensagem-confirmacao {
    background-color: #d4edda;
    color: #155724;
    padding: 15px;
    margin: 20px 0;
    border-radius: 5px;
    border: 1px solid #c3e6cb;
    display: none;
}

/* Footer */
footer {
    background-color: #333;
    color: #fff;
    text-align: center;
    padding: 20px 0;
    margin-top: 40px;
}
